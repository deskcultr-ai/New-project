# Required for Admin -> Users & Teams invite emails.
# Set this as a Cloudflare Worker secret, not a public var:
#   npx -p node@22 -c "node node_modules/wrangler/bin/wrangler.js secret put RESEND_API_KEY"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
INVITE_FROM_EMAIL="Deskcultr <onboarding@resend.dev>"

# Platform-owner gate for /platform-admin/requests (comma-separated emails).
# The NEXT_PUBLIC_ copy is a client-side UX check only; the API route
# independently re-checks the server-only one before touching data.
PLATFORM_OWNER_EMAILS=owner@example.com
NEXT_PUBLIC_PLATFORM_OWNER_EMAILS=owner@example.com

# Required by every /api/invites*, /api/org-requests, and
# /api/platform-admin route. From the Supabase dashboard: Project Settings
# -> API -> service_role key. Set this as a Cloudflare Worker secret, not a
# public var:
#   npx -p node@22 -c "node node_modules/wrangler/bin/wrangler.js secret put SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
