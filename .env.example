NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFmc2tzeHlyeXZ4amFmdGJsdWZ2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQyNzAwODcsImV4cCI6MjA5OTg0NjA4N30.BZEeKehKiX8_Mvv4CwQmkihKHQ0kbalpiCudsASvhL4

# Optional deployment/runtime integrations.
CLOUDFLARE_ACCOUNT_ID=00ed34521d1e32769bab314261aced44
CLOUDFLARE_PROJECT_NAME=deskculture

# Client-side Sentry error monitoring (src/instrumentation-client.ts).
# Public by design -- Sentry DSNs are meant to be embedded in the browser
# bundle, they only accept writes (error reports), not reads. Leave unset
# and the app runs exactly as before; Sentry.init() no-ops. Get this from
# Sentry -> Project Settings -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Not read by application code -- invite/OTP/magic-link emails are sent by
# Supabase Auth itself now, configured with this same key as its SMTP
# password (Dashboard -> Authentication -> Emails -> SMTP Settings). Kept
# here only as a reminder of which key that dashboard setting points to.
# See docs/AUTH_WORKFLOW.md for the full setup steps.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
INVITE_FROM_EMAIL="Deskcultr <onboarding@resend.dev>"

# Platform-owner gate for /platform-admin/requests (comma-separated emails).
# The NEXT_PUBLIC_ copy is a client-side UX check only; the API route
# independently re-checks the server-only one before touching data.
PLATFORM_OWNER_EMAILS=owner@example.com
NEXT_PUBLIC_PLATFORM_OWNER_EMAILS=owner@example.com

# Required by every /api/invites*, /api/org-requests, and
# /api/platform-admin route. From the Supabase dashboard: Project Settings
# -> API -> service_role key. Set this as a Cloudflare Worker secret, not a
# public var:
#   npx -p node@22 -c "node node_modules/wrangler/bin/wrangler.js secret put SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
